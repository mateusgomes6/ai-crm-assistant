from crewai import Agent, LLM
from pydantic import BaseModel, Field
from tools.rag_tool import RAGLeadTool

llm = LLM(model="groq/llama-3.3-70b-versatile", temperature=0.2, num_retries=3)

rag_tool = RAGLeadTool()

lead_analyzer = Agent(
    role="Analista de Inteligência de Leads",
    goal=(
        "Analisar profundamente perfis de leads B2B. Identificar intenção de compra, "
        "pontos de dor, stack tecnológico, maturidade da empresa e sinais de orçamento. "
        "Usar dados históricos de leads similares para prever a probabilidade de conversão."
    ),
    backstory=(
        "Você é um analista sênior de inteligência de vendas B2B com mais de 10 anos "
        "identificando leads de alto valor em empresas SaaS. Você combina dados firmográficos, "
        "sinais comportamentais e padrões históricos alimentados por RAG para construir perfis "
        "de leads extremamente precisos. Você nunca adivinha — você raciocina a partir de evidências."
    ),
    tools=[rag_tool],
    llm=llm,
    verbose=True,
    memory=False,
)


class LeadAnalysisOutput(BaseModel):
    lead_score: int = Field(description="Score de 0 a 100")
    intent: str = Field(description="Baixa, Média ou Alta")
    intent_reason: str = Field(description="Justificativa da intenção de compra")
    pain_points: list[str] = Field(description="3 principais pontos de dor")
    tech_stack_guess: list[str] = Field(description="Stack tecnológico provável")
    buying_committee: list[str] = Field(description="Membros do comitê de compras")
    similar_leads_found: int = Field(description="Quantidade de leads similares encontrados")
    analyst_notes: str = Field(description="Notas do analista")


def build_analyze_task(lead_input: dict):
    from crewai import Task

    return Task(
        description=f"""
        Analise o seguinte lead e produza um relatório estruturado de inteligência.

        Dados do lead:
        - Tipo de empresa : {lead_input['company']}
        - Cargo do contato: {lead_input['role']}
        - Segmento        : {lead_input['segment']}
        - Notas extras    : {lead_input.get('notes', 'Nenhuma')}

        Etapas:
        1. Use a ferramenta search_similar_leads para buscar leads similares (query: "{lead_input['role']} {lead_input['segment']}").
        2. Com base nos resultados, identifique os 3 principais pontos de dor típicos para este perfil.
        3. Estime a intenção de compra (Baixa / Média / Alta) com justificativa.
        4. Atribua um score de lead de 0 a 100 com base em: senioridade do cargo, adequação ao segmento, sinais de porte da empresa.
        5. Liste o provável stack tecnológico e os membros do comitê de compras.

        IMPORTANTE: Responda APENAS com o JSON, sem explicações ou texto adicional.
        """,
        agent=lead_analyzer,
        expected_output="Objeto JSON com relatório de inteligência do lead",
        output_json=LeadAnalysisOutput,
    )